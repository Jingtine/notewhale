# Local database. Leave this empty to use ./notewhale.db.
DATABASE_URL=

# Local file storage.
NOTEWHALE_UPLOAD_DIR=uploads

# Auth token signing key for local development.
NOTEWHALE_SECRET_KEY=notewhale-local-dev-secret-change-before-deploy
NOTEWHALE_TOKEN_EXPIRE_DAYS=14

# Text model for AI note generation.
# The backend expects an OpenAI-compatible /chat/completions endpoint.
NOTEWHALE_TEXT_API_URL=https://api.deepseek.com/chat/completions
NOTEWHALE_TEXT_API_KEY=replace-with-your-text-model-key
NOTEWHALE_TEXT_MODEL=deepseek-chat

# Vision model for DDL screenshot recognition.
# Use a model endpoint that supports OpenAI-compatible image_url messages.
NOTEWHALE_VISION_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
NOTEWHALE_VISION_API_KEY=replace-with-your-vision-model-key
NOTEWHALE_VISION_MODEL=glm-4v-flash
